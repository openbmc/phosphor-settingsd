      "side": 1,
      "message": "Why did we choose to use a signal instead of sd_notify or a dbus request?",
      "range": {
        "startLine": 24,
        "startChar": 0,
        "endLine": 25,
        "endChar": 28
      },
      "revId": "595c21ddcf1047b96f196e6de5d1b25e27879a15",
